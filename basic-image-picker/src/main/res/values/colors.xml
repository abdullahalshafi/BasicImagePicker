<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <color name="ef_colorPrimary" tools:override="true">@color/basic_image_picker_colorPrimary
    </color>
    <color name="ef_colorPrimaryDark" tools:override="true">
        @color/basic_image_picker_colorPrimaryDark
    </color>
    <color name="ef_colorAccent" tools:override="true">@color/basic_image_picker_colorAccent</color>
    <color name="ef_colorTextPrimary" tools:override="true">
        @color/basic_image_picker_colorTextPrimary
    </color>

    <color name="ef_white">#FFFFFF</color>
    <color name="ef_grey">#9E9E9E</color>
    <color name="ef_black_alpha_50">#80000000</color>
    <color name="ef_black_alpha_aa">#AA000000</color>
    <color name="ef_teal">#009688</color>

    <!--
        Sentinel #01000001 means "consumer did not override this color".
        ImageUtilHelper compares against this sentinel at runtime; anything else is treated
        as an explicit override and takes priority over the auto-derived theme colors.
        Real fallbacks live inline in ef_AppTheme (styles.xml).
    -->
    <color name="basic_image_picker_toolbar_icon_color">#01000001</color>
    <color name="basic_image_picker_colorPrimary">#01000001</color>
    <color name="basic_image_picker_colorPrimaryDark">#01000001</color>
    <color name="basic_image_picker_colorAccent">#FF4081</color>
    <color name="basic_image_picker_colorTextPrimary">#01000001</color>

</resources>
